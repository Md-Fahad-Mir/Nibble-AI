# NibblAI Backend — Environment Configuration Template
# ============================================================
# Copy this file to .env and fill in real values for your environment.
# Never commit .env to git; it is gitignored.
#
# For production, use a secret manager (AWS Secrets Manager, HashiCorp Vault, etc.)
# and inject these as environment variables at runtime — never bake into images.
#
# Mandatory fields (marked [REQUIRED]) will cause the app to fail if missing in production.
# Optional fields have sensible defaults and may be omitted for local development.

# ============================================================
# DJANGO CORE — Security & Basic Config
# ============================================================

# [REQUIRED in PROD] Secret key used for Django crypto (JWT, sessions, CSRF).
# Generate a strong random key: python -c "import secrets; print(secrets.token_urlsafe(64))"
# NEVER use the default django-insecure-* value in production.
# Rotating this invalidates all sessions and JWTs.
SECRET_KEY=dev-insecure-change-me-to-a-strong-random-key-at-least-50-chars

# [REQUIRED in PROD] Comma-separated list of allowed request Host headers.
# Prevents Host-header poisoning. In dev, localhost is fine; in prod, your domain.
ALLOWED_HOSTS=localhost,127.0.0.1

# Debug mode: verbose error pages, live reloading, etc.
# MUST be False in production (leaks code/settings/stack traces).
DEBUG=True

# Django settings module to load.
# Local dev uses core.settings.dev (manage.py default).
# Production uses core.settings.prod (wsgi/asgi default).
# Test uses core.settings.test.
DJANGO_SETTINGS_MODULE=core.settings.dev

# [PROD] Origins trusted for CSRF on unsafe methods (admin login over HTTPS).
# Comma-separated, full scheme + host. Required if you use the Django admin
# behind HTTPS. Example: https://api.nibblai.app,https://www.nibblai.app
# CSRF_TRUSTED_ORIGINS=https://api.nibblai.app

# [PROD] Redirect HTTP->HTTPS inside the app (default True in prod settings).
# Set to False ONLY when an upstream proxy already forces HTTPS, to avoid
# redirect loops. The /api/v1/health/ endpoint is always exempt.
# SECURE_SSL_REDIRECT=True
# HSTS max-age in seconds (default 2592000 = 30 days). Raise to 31536000 once
# you are confident every subdomain is HTTPS-only.
# SECURE_HSTS_SECONDS=2592000

# ============================================================
# CORS — Cross-Origin Resource Sharing (browser frontends)
# ============================================================
# [REQUIRED in PROD] Comma-separated list of frontend origins allowed to call
# the API from a browser. Full scheme + host, NO trailing slash. Without this,
# every cross-origin request is blocked by the browser's same-origin policy.
# Local dev (core.settings.dev) already allows localhost:3000 and :5173.
# Production example:
# CORS_ALLOWED_ORIGINS=https://app.joinnibbl.com
#
# Send Access-Control-Allow-Credentials: true (default True). Required when the
# frontend sends cookies or Authorization headers. Origins must be explicit
# (never "*") when this is true — the settings never enable a wildcard origin.
# CORS_ALLOW_CREDENTIALS=True
#
# Cache preflight (OPTIONS) results in the browser, in seconds (default 86400 = 24h).
# CORS_PREFLIGHT_MAX_AGE=86400
#
# Only if the frontend sends a custom request header beyond the defaults
# (accept, authorization, content-type, origin, x-csrftoken, x-requested-with):
# CORS_EXTRA_ALLOW_HEADERS=x-my-custom-header

# ============================================================
# DATABASE
# ============================================================
# LOCAL DEV: leave DATABASE_URL unset — the app uses SQLite automatically
# (a db.sqlite3 file in the project root). No database server required.
#
# PRODUCTION: set DATABASE_URL to your AWS RDS PostgreSQL endpoint. The prod
# settings REQUIRE it (the app refuses to start without it) and enable
# persistent connection pooling. Enforce TLS to RDS with ?sslmode=require.
#
# Production example (AWS RDS):
# DATABASE_URL=postgres://USER:PASSWORD@nibblai.abc123.us-east-1.rds.amazonaws.com:5432/nibblai?sslmode=require
#
# Persistent-connection lifetime in seconds (prod only; default 60).
# DB_CONN_MAX_AGE=60
#
# Tip: to point LOCAL dev at Postgres instead of SQLite, just set DATABASE_URL.

# ============================================================
# CACHING & RATE LIMITING (Optional, defaults shown)
# ============================================================
# Backs DRF throttling. With multiple gunicorn workers this MUST be Redis:
# the per-process LocMem cache would give each worker its own throttle
# counters, silently multiplying every rate limit by the worker count.
#
# In prod settings, the cache switches to Redis automatically when REDIS_URL
# is set; otherwise it falls back to LocMem (fine for a single dev process).
# With the Docker stacks, the compose network exposes Redis as host "redis":
# REDIS_URL=redis://redis:6379/0
# Without Docker (Redis on the host):
# REDIS_URL=redis://localhost:6379/0

# Throttle rates (requests per time window).
# These are scopes: "anon" = unauthenticated, "user" = authenticated, "auth" = brute-force protected.
THROTTLE_ANON=60/min
THROTTLE_USER=1000/hour
THROTTLE_AUTH=10/min

# Logging level.
LOG_LEVEL=INFO

# ============================================================
# EMAIL / SMTP — For verification codes, password resets, notifications
# ============================================================
# In local dev, EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# prints emails to stdout. For real email, use SMTP or a transactional provider.
#
# Recommendation for production:
#   - Use SendGrid, AWS SES, Mailgun, or Postmark (not personal Gmail).
#   - These provide better deliverability, rate limits, and scoped API keys.
#   - A Gmail app-password is tied to a personal account and has rate limits.

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True

# SMTP credentials. Required if EMAIL_BACKEND=.smtp.EmailBackend
# For SendGrid: user = "apikey", password = "SG.xxx..."
# For AWS SES: user and password from IAM credentials.
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-app-password-or-api-key

# From address for sent emails. Should be a domain you control (for SPF/DKIM).
DEFAULT_FROM_EMAIL=no-reply@nibblai.app

# ============================================================
# AI PROVIDERS — For review prompt generation (Optional)
# ============================================================
# The app tries Claude → ChatGPT → Gemini in order and falls back to a mock if none is set.
# All are optional; pick one (or none to use deterministic mocks).
# These are spend-bearing keys — set usage limits on the provider side.

# Anthropic (Claude)
# Get key at: console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI (ChatGPT)
# Get key at: platform.openai.com/account/api-keys
# NEVER commit your real key; rotate if exposed.
OPENAI_API_KEY=sk-proj-your-key-here
OPENAI_MODEL=gpt-4o

# Google Generative AI (Gemini)
# Get key at: ai.google.dev/tutorials/setup
GOOGLE_AI_API_KEY=AIza-your-key-here
GOOGLE_STUDIO_API_KEY=AIza-your-key-here
GOOGLE_MODEL=gemini-1.5-pro

# ============================================================
# PUSH NOTIFICATIONS — Firebase Cloud Messaging (Optional)
# ============================================================
# Without a key, push notifications are mocked (logged to stdout).
# For real FCM, provide the server key (deprecated) or use HTTP v1 auth + service account JSON.
#
# FCM is deprecating legacy server keys in favor of HTTP v1 + Google Cloud service accounts.
# Plan to migrate to: GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

FCM_SERVER_KEY=AAAA-your-fcm-key-here

# ============================================================
# SMS / PHONE VERIFICATION — Twilio (Planned integration, not yet wired)
# ============================================================
# Currently mocked (codes logged). Wire up when Twilio is ready.

# TWILIO_ACCOUNT_SID=ACxx...
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_VERIFY_SID=VAxx...

# ============================================================
# OCR PROVIDER — Receipt scanning (Planned integration, mocked for now)
# ============================================================
# Currently accepts structured digital receipts. Real OCR (Veryfi/Taggun/AWS Textract) wires here.

# VERYFI_CLIENT_ID=your-client-id
# VERYFI_API_KEY=your-api-key

# ============================================================
# S3 / FILE STORAGE — Receipt images (Planned integration, local disk for now)
# ============================================================
# Currently stores receipt images in MEDIA_ROOT (local disk).
# Swap to S3 via django-storages when ready.

# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_STORAGE_BUCKET_NAME=nibblai-receipts
# AWS_S3_REGION_NAME=us-east-1

# ============================================================
# PAYOUTS / ESCROW FUNDING — Payment processors (Planned integrations, mocked for now)
# ============================================================
# Currently mocked. Wire up for real customer withdrawals (PayPal/Venmo) and brand funding.

# PayPal
# PAYPAL_CLIENT_ID=your-client-id
# PAYPAL_CLIENT_SECRET=your-secret
# PAYPAL_MODE=sandbox

# ============================================================
# BUSINESS TUNING — Feature flags & thresholds (Optional, all have safe defaults)
# ============================================================
# These control business logic (not secrets). Store in env or DB later.

# Referral program reward (dollars)
REFERRAL_BONUS_AMOUNT=5.00

# Reservation system (spec 1.3)
RESERVATION_EXPIRY_DAYS=7
RESERVATION_GLOBAL_CAP=100000

# Receipts / fraud handling
MAX_ACTIVE_CLAIMS=25

# Reviews module
REVIEW_REWARD_AMOUNT=1.00
REVIEW_PRODUCT_COOLDOWN_DAYS=90
REVIEW_MAX_PER_RECEIPT=5
REVIEW_SESSION_EXPIRY_DAYS=7
REVIEW_HOLD_DAYS=30
REVIEW_AUTO_PUBLISH_MIN_RATING=3

# Payouts
PAYOUT_MIN_AMOUNT=1.00

# Notifications
NOTIFY_RECEIPT_REMINDER_AFTER_HOURS=24
NOTIFY_REVIEW_REMINDER_AFTER_HOURS=24
NOTIFY_INACTIVE_AFTER_DAYS=14
NOTIFY_DEDUPE_HOURS=24
NOTIFY_NEW_OFFER_DEDUPE_DAYS=7

# Public URL for campaign links, QR codes, etc.
PUBLIC_BASE_URL=http://localhost:8000

# ============================================================
# DOCKER / CONTAINER DEPLOYMENT
# ============================================================
# These tune how the image runs (consumed by entrypoint.sh). All have safe
# defaults. Database choice is driven entirely by DATABASE_URL (see DATABASE
# section above): unset -> SQLite (local), RDS DSN -> PostgreSQL (production).

# --- Cache ---
# Production needs a shared Redis so DRF throttle counters are consistent across
# gunicorn workers (ElastiCache, a Redis container, etc.). Unset -> LocMem.
# REDIS_URL=redis://your-redis-host:6379/0

# Host port the backend container publishes (map to your reverse proxy).
# Use 127.0.0.1:8000 if the proxy runs on the same host.
# BACKEND_PORT=8000

# --- gunicorn (prod) ---
# Rule of thumb: workers = (2 x CPU cores) + 1. Threads help IO-bound views.
# GUNICORN_WORKERS=3
# GUNICORN_THREADS=2
# GUNICORN_TIMEOUT=60
# GUNICORN_LOG_LEVEL=info

# --- entrypoint startup behavior ---
# Wait for the DB before starting (1=yes). Run migrations on boot (1=yes).
# Collect static at boot (prod images already bake static at build time -> 0).
# WAIT_FOR_DB=1
# DB_WAIT_TIMEOUT=60
# RUN_MIGRATIONS=1
# RUN_COLLECTSTATIC=0

# --- scheduler (prod `scheduler` service) ---
# Seconds between sweeps of the periodic management commands.
# SCHEDULER_INTERVAL_SECONDS=3600

# ============================================================
# SUMMARY OF REQUIRED KEYS (Production Checklist)
# ============================================================
# Before deploying to production, ensure you have provided:
#
# MANDATORY:
#   ✓ SECRET_KEY (strong, 50+ chars, not django-insecure-*)
#   ✓ ALLOWED_HOSTS (your domain)
#   ✓ DATABASE_URL (AWS RDS PostgreSQL DSN; prod refuses to start without it)
#                  — local dev needs nothing here; it falls back to SQLite
#   ✓ EMAIL credentials (EMAIL_HOST_USER, EMAIL_HOST_PASSWORD)
#   ✓ DEBUG=False
#
# OPTIONAL (if you use them):
#   ○ AI keys (ANTHROPIC_API_KEY, OPENAI_API_KEY, GOOGLE_AI_API_KEY)
#   ○ FCM_SERVER_KEY (push notifications)
#   ○ REDIS_URL (must be set for production throttling)
#   ○ AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY (S3 storage)
#   ○ PAYPAL_CLIENT_ID, PAYPAL_CLIENT_SECRET (payouts)
#
# SCAFFOLDS (not yet integrated):
#   • TWILIO_* (SMS verification)
#   • VERYFI_* (OCR)
#
# Run the deployment check:
#   python manage.py check --deploy --settings=core.settings.prod
