# ═══════════════════════════════════════════════════════════════════════
# Nibbl AI — Backend Environment Variables Template
# Copy per environment and fill in real values. NEVER commit a filled copy.
# Variable names below are exactly what core/settings reads (django-environ).
# ═══════════════════════════════════════════════════════════════════════

# --- Django core ---
DJANGO_SETTINGS_MODULE=core.settings.prod       # local dev: core.settings.dev
SECRET_KEY=generate-a-strong-random-key         # python -c "import secrets; print(secrets.token_urlsafe(64))"
DEBUG=False
ALLOWED_HOSTS=api.joinnibbl.com,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://api.joinnibbl.com  # full scheme+host, comma-separated

# --- Database ---
# LOCAL DEV: leave DATABASE_URL UNSET -> the app uses SQLite (db.sqlite3). No server.
# PRODUCTION: set DATABASE_URL to your AWS RDS PostgreSQL endpoint (REQUIRED by
# the prod settings — the app refuses to start without it). Enforce TLS with sslmode.
DATABASE_URL=postgres://nibblai_admin:PASSWORD@your-rds-endpoint.us-west-1.rds.amazonaws.com:5432/nibblai?sslmode=require
# DB_CONN_MAX_AGE=60

# --- Cache / throttling (production) ---
# Shared Redis keeps DRF throttle counters consistent across gunicorn workers
# (ElastiCache or a Redis container). Unset -> per-process LocMem (dev only).
REDIS_URL=redis://your-redis-host:6379/0

# --- Email (SMTP; use a transactional provider in production, not personal Gmail) ---
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=your-smtp-api-key
DEFAULT_FROM_EMAIL=no-reply@joinnibbl.com

# --- AI providers (optional; leave empty for deterministic mocks) ---
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_AI_API_KEY=

# --- Push notifications (optional) ---
# FCM_SERVER_KEY=

# --- Logging ---
LOG_LEVEL=INFO

# --- Superuser bootstrap (entrypoint runs `manage.py ensure_superuser`) ---
# The model logs in by EMAIL (there is no username field).
DJANGO_SUPERUSER_EMAIL=admin@joinnibbl.com
DJANGO_SUPERUSER_PASSWORD=use-a-strong-password
# DJANGO_SUPERUSER_FULL_NAME=Admin
